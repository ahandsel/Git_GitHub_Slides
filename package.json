{
  "name": "git-github-slides",
  "version": "0.0.1",
  "private": true,
  "description": "Slides and guides for a Git and GitHub introduction.",
  "keywords": [],
  "license": "UNLICENSED",
  "author": "",
  "type": "module",
  "scripts": {
    "lint": "pnpm run lint-code && pnpm run lint-md",
